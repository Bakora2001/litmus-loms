# ==========================================================
# Litmus LOMS - Backend Environment Variables
# ==========================================================

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=litmus_solutions_super_secret_change_this_in_production_2026
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------
# PostgreSQL (Render) - provided instance details
# Use the EXTERNAL url when running the API from your own
# machine / any host outside Render.
# Use the INTERNAL url instead when you deploy this backend
# as a Render Web Service in the SAME region (Oregon) -
# it's faster and doesn't count against external bandwidth.
# ----------------------------------------------------------
DATABASE_URL=postgresql://litmus_user:D75Q6Jo51nFGfg8WYrx4dnhCoY3Vc2Nx@dpg-d9655nv7f7vs73cu7f0g-a.oregon-postgres.render.com/litmus_db_5zmq
# DATABASE_URL_INTERNAL=postgresql://litmus_user:D75Q6Jo51nFGfg8WYrx4dnhCoY3Vc2Nx@dpg-d9655nv7f7vs73cu7f0g-a/litmus_db_5zmq

PGSSL=true

# Frontend origin allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# Bulk SMS - plug in your provider's Sender ID API credentials here
SMS_PROVIDER_API_URL=
SMS_PROVIDER_API_KEY=
SMS_SENDER_ID=LITMUS

# Currency / defaults
DEFAULT_CURRENCY=KES
